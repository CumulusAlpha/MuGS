<mujoco model="first_person_kitchen">
  <compiler angle="radian"/>
  <option timestep="0.002" gravity="0 0 -9.81"/>

  <visual>
    <global offwidth="640" offheight="480"/>
    <quality shadowsize="4096"/>
  </visual>

  <asset>
    <texture name="grid" type="2d" builtin="checker" width="512" height="512" rgb1=".1 .2 .3" rgb2=".2 .3 .4"/>
    <material name="grid" texture="grid" texrepeat="1 1" texuniform="true"/>
  </asset>

  <worldbody>
    <light pos="2 0 3" dir="-0.5 0 -1" directional="false"/>
    <light pos="1.5 1 2.5" dir="0 -0.3 -1" directional="false"/>
    <geom name="floor" type="plane" size="5 5 0.1" material="grid"/>

    <!-- Robot wrist with first-person camera -->
    <body name="wrist" pos="1.5 0 1.2" euler="0 0.4 0">
      <camera name="wrist_cam" pos="0 0 0" euler="0 0 0" fovy="65"/>

      <!-- Gripper base -->
      <geom name="gripper_base" type="box" size="0.025 0.035 0.025"
            rgba="0.3 0.3 0.35 0.8" pos="0 0 -0.06"/>

      <!-- Left finger -->
      <body name="left_finger" pos="-0.03 0 -0.09">
        <geom name="gripper_left" type="box" size="0.006 0.045 0.018"
              rgba="0.4 0.4 0.45 0.85"/>
      </body>

      <!-- Right finger -->
      <body name="right_finger" pos="0.03 0 -0.09">
        <geom name="gripper_right" type="box" size="0.006 0.045 0.018"
              rgba="0.4 0.4 0.45 0.85"/>
      </body>
    </body>

    <!-- Desktop objects -->
    <!-- Red mug - target object -->
    <body name="mug" pos="1.75 0.05 1.0">
      <joint type="free"/>
      <geom name="mug_body" type="cylinder" size="0.035 0.08"
            rgba="0.85 0.25 0.2 1" mass="0.18"/>
      <geom name="mug_handle" type="box" size="0.01 0.025 0.05"
            rgba="0.85 0.25 0.2 1" pos="0.04 0 0.02" mass="0.02"/>
    </body>

    <!-- Blue bowl -->
    <body name="bowl" pos="2.0 -0.25 0.96">
      <joint type="free"/>
      <geom name="bowl_geom" type="cylinder" size="0.065 0.035"
            rgba="0.25 0.55 0.85 1" mass="0.15"/>
    </body>

    <!-- White plate -->
    <body name="plate" pos="1.55 0.35 0.91">
      <geom name="plate_geom" type="cylinder" size="0.095 0.012"
            rgba="0.92 0.92 0.95 1" mass="0.12"/>
    </body>

    <!-- Green apple -->
    <body name="apple" pos="1.9 0.2 0.95">
      <joint type="free"/>
      <geom name="apple_geom" type="sphere" size="0.04"
            rgba="0.3 0.75 0.25 1" mass="0.08"/>
    </body>

    <!-- Table (invisible, just for collision) -->
    <geom name="table" type="box" size="0.8 0.6 0.05"
          pos="1.8 0 0.85" rgba="0.6 0.5 0.4 0"/>
  </worldbody>
</mujoco>
