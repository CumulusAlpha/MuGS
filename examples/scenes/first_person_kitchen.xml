<mujoco model="first_person_kitchen">
  <compiler angle="radian"/>
  <option timestep="0.002" gravity="0 0 -9.81"/>

  <visual>
    <global offwidth="640" offheight="480"/>
    <quality shadowsize="4096"/>
  </visual>

  <asset>
    <texture name="grid" type="2d" builtin="checker" width="512" height="512" rgb1=".1 .2 .3" rgb2=".2 .3 .4"/>
    <material name="grid" texture="grid" texrepeat="1 1" texuniform="true"/>
  </asset>

  <worldbody>
    <light pos="2 0 0" dir="-0.5 0 -1" directional="false"/>
    <light pos="1.5 1 -1" dir="0 -0.3 -1" directional="false"/>
    <geom name="floor" type="plane" size="5 5 0.1" material="grid"/>

    <!-- First-person camera (Camera 117 from kitchen.ply) -->
    <!-- Directly in world frame for exact alignment -->
    <!-- FOV: 35.55° (from fx=3231.58, fy=3240.81, image=3115x2078) -->
    <!-- xyaxes: xaxis (right) + yaxis (up), derived from rotation matrix -->
    <camera name="wrist_cam"
            pos="1.563101 1.205030 -2.343449"
            xyaxes="0.760188 -0.366818 0.536245 0.413893 0.909633 0.035494"
            fovy="35.55"/>

    <!-- Robot gripper in view (slightly below camera) -->
    <body name="wrist" pos="1.563101 1.205030 -2.543449">
      <!-- Gripper base -->
      <geom name="gripper_base" type="box" size="0.025 0.035 0.025"
            rgba="0.3 0.3 0.35 0.8" pos="0 0 0"/>

      <!-- Left finger -->
      <body name="left_finger" pos="-0.03 0 -0.04">
        <geom name="gripper_left" type="box" size="0.006 0.045 0.018"
              rgba="0.4 0.4 0.45 0.85"/>
      </body>

      <!-- Right finger -->
      <body name="right_finger" pos="0.03 0 -0.04">
        <geom name="gripper_right" type="box" size="0.006 0.045 0.018"
              rgba="0.4 0.4 0.45 0.85"/>
      </body>
    </body>

    <!-- Desktop objects (positioned near yellow excavator in view) -->
    <!-- Camera at [1.56, 1.21, -2.34], looking forward-down -->
    <!-- Place objects on tabletop in front of camera -->

    <!-- Table surface (invisible collision) -->
    <geom name="table" type="box" size="0.6 0.4 0.02"
          pos="2.0 1.1 -3.25" rgba="0.6 0.5 0.4 0"/>

    <!-- Red mug - next to excavator -->
    <body name="mug" pos="2.15 1.15 -3.15">
      <joint type="free"/>
      <geom name="mug_body" type="cylinder" size="0.04 0.09"
            rgba="0.9 0.2 0.15 1" mass="0.2"/>
      <geom name="mug_handle" type="box" size="0.012 0.03 0.06"
            rgba="0.9 0.2 0.15 1" pos="0.048 0 0.03" mass="0.02"/>
    </body>

    <!-- Blue bowl - left side -->
    <body name="bowl" pos="1.85 1.25 -3.18">
      <joint type="free"/>
      <geom name="bowl_geom" type="cylinder" size="0.07 0.04"
            rgba="0.2 0.5 0.9 1" mass="0.18"/>
    </body>

    <!-- White plate - back -->
    <body name="plate" pos="2.25 1.0 -3.23">
      <geom name="plate_geom" type="cylinder" size="0.10 0.015"
            rgba="0.95 0.95 0.98 1" mass="0.15"/>
    </body>

    <!-- Green apple - right side -->
    <body name="apple" pos="2.15 0.95 -3.19">
      <joint type="free"/>
      <geom name="apple_geom" type="sphere" size="0.045"
            rgba="0.3 0.8 0.2 1" mass="0.1"/>
    </body>
  </worldbody>
</mujoco>
